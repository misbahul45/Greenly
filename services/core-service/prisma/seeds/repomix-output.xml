    if (o.paymentStatus === 'SUCCESS') {
      await prisma.shopLedger.create({
        data: {
          shopId,
          type: 'CREDIT',
          amount: netAmount,
          reference: `PAYMENT_${payment.id}`,
          description: `Payment for order ${order.id}`,
        },
      })
    }
  }

  console.log('✅ Orders Seeded Successfully')
}
