  async update(
    @Param(new ZodValidationPipe(roleIdParamSchema))
    params: RoleIdParamDTO,
    @Body(new ZodValidationPipe(updateRoleSchema))
    body: UpdateRoleDTO,
  ) {
    return ErrorHandler(() =>
      this.rolesService.update(params.id, body.name),
    )
