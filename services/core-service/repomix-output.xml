  // CUSTOMER       : cart, order pribadi, me, follow shop, validate promo
  // SYSTEM         : system.manage
  // ============================================================

  const rolePermissionsMap: Record<string, string[]> = {
    SUPER_ADMIN: permissions,

    ADMIN: [
      'user.read',
      'user.create',
      'user.update',
      'user.suspend',
      'role.read',
      'role.create',
      'role.update',
