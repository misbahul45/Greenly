describe('OrderService', () => {
  let service: OrderService;
  let repo: any;
  let publisher: any;
  let db: any;

  beforeEach(async () => {
    repo = {
      findMany: jest.fn(),
      count: jest.fn(),
      findOne: jest.fn(),
    };

    publisher = {
      publishShopOrderStatusChanged: jest.fn(),
      publishRefundProcessed: jest.fn(),
    };

    db = {
      $transaction: jest.fn((cb) => cb(db)),
      order: {
        findUnique: jest.fn(),
        findFirst: jest.fn(),
        update: jest.fn(),
      },
      shopLedger: {
        create: jest.fn(),
      },
      shop: {
        update: jest.fn(),
      },
