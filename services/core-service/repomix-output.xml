export const ListLedgersQuerySchema = z.object({
  type: z.enum(['CREDIT', 'DEBIT']).optional(),
  dateFrom: z.string().datetime().optional(),
  dateTo: z.string().datetime().optional(),
  page: z.coerce.number().int().min(1).default(1),
