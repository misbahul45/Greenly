# Greenly core-service local environment.
# Do not use these values in production.

NODE_ENV=development
PORT=3000

DATABASE_HOST=mysql
DATABASE_PORT=3307
DATABASE_USER=greenly
DATABASE_PASSWORD=change-me
DATABASE_NAME=greenly_core
DATABASE_URL=mysql://greenly:change-me@mysql:3306/greenly_core

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

RABBITMQ_URL=amqp://greenly:change-me@rabbitmq:5672/
RABBITMQ_EXCHANGE=greenly_events
RABBITMQ_CORE_QUEUE=greenly_core_events
RABBITMQ_QUEUE=greenly_queue
RABBITMQ_NO_ACK=false

OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISH_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50

ML_ENGINE_URL=http://ml-engine:8000
CATALOG_SERVICE_URL=http://catalog-service:8081
API_URL=http://localhost/api/core

JWT_ACCESS_SECRET_KEY=change-me-at-least-32-characters
JWT_REFRESH_SECRET_KEY=change-me-at-least-32-characters
JWT_ACCESS_EXPIRES=30d
JWT_REFRESH_EXPIRES=30d

EMAIL_JS_SERVICE_ID=
EMAIL_JS_PUBLIC_ID=
EMAIL_JS_PRIVATE_KEY=
EMAIL_JS_VERIFY_EMAIL_TEMPLATE_ID=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost/payment-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost/payment-cancel?session_id={CHECKOUT_SESSION_ID}
STRIPE_CURRENCY=idr
STRIPE_CHECKOUT_EXPIRES_HOURS=24
