# Greenly ml-engine environment.
#
# Local Development (Docker Compose):
#   RABBITMQ_URL=amqp://greenly:change-me@rabbitmq:5672/
#   REDIS_URL=redis://redis:6379/0
#   CATALOG_SERVICE_URL=http://catalog-service:8081
#   CORE_SERVICE_URL=http://core-service:3000
#
# Production (Managed Cloud):
#   RABBITMQ_URL=amqps://... (CloudAMQP)
#   REDIS_URL=rediss://... (Upstash Redis - TLS required)
#   CATALOG_SERVICE_URL=https://catalog.railway.app
#   CORE_SERVICE_URL=https://core.railway.app
#
# Future: HuggingFace Inference API gateway.

APP_ENV=development
ML_PORT=8000

MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CATALOG_SERVICE_URL=http://catalog-service:8081
CORE_SERVICE_URL=http://core-service:3000

# CloudAMQP: amqps://user:password@host.cloudamqp.com/vhost
RABBITMQ_URL=amqp://greenly:change-me@rabbitmq:5672/
# Upstash: rediss://default:password@host:6379
REDIS_URL=redis://redis:6379/0

FAISS_INDEX_PATH=app/storage/indexes/products.faiss
PRODUCT_META_PATH=app/storage/indexes/products_meta.json
ML_INTERNAL_TOKEN=change-me-local-dev-token

# Set to true for lightweight local smoke tests without loading sentence-transformers.
ML_USE_HASH_EMBEDDINGS=false
HUGGINGFACE_API_TOKEN=change-me
