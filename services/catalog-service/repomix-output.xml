		categories.POST("", auth, middleware.RequireRole("admin"), handler.Create)
		categories.PUT("/:id", auth, middleware.RequireRole("admin"), handler.Update)
		categories.DELETE("/:id", auth, middleware.RequireRole("admin"), handler.Delete)
	}
