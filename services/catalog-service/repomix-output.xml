	}

	err := h.service.Recalculate(c.Request.Context(), productID)
	if err != nil {
		c.Error(middleware.NewAppError(500, "Failed to recalculate active price", err))
		return
	}
	utils.OK(c, gin.H{"message": "Active price recalculated"})
}

