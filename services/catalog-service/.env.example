# Greenly catalog-service local environment.
# Do not use these values in production.

APP_ENV=development
GIN_MODE=debug
PORT=8081

MONGODB_URL=mongodb://root:change-me@mongodb:27017/?authSource=admin
MONGODB_URI=mongodb://root:change-me@mongodb:27017/?authSource=admin

CORE_SERVICE_URL=http://core-service:3000

REDIS_HOST=redis
REDIS_PORT=6379

RABBITMQ_URL=amqp://greenly:change-me@rabbitmq:5672/
RABBITMQ_NO_ACK=false

JWT_ACCESS_SECRET_KEY=change-me-at-least-32-characters

# Optional ImageKit upload integration.
IMAGEKIT_PRIVATE_KEY=
