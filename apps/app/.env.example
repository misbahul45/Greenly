# Greenly Flutter app environment.
# This app uses flutter_dotenv and loads .env as a Flutter asset.
# Copy this file to apps/app/.env before running.
#
# Android emulator: use http://10.0.2.2/api
# iOS simulator: http://localhost/api usually works.
# Physical device: use http://<your-machine-lan-ip>/api

API_URL=http://10.0.2.2/api
