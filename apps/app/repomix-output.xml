    _locationGranted = false;
    widget.onLocationChanged(false);
  });

  void _skipNotif() => setState(() {
    _notifResolved = true;
    _notifGranted = false;
    widget.onNotifChanged(false);
  });

  bool get _canFinish => _locationResolved || _notifResolved;

