                        const SizedBox(height: UIConstants.spacingXS),
                        Text(
                          'SKU: ${product.sku}',
                          style: TextStyle(
                            fontSize: 12,
                            color: Colors.grey[500],
                          ),
                        ),
                        const SizedBox(height: UIConstants.spacingM),
                        PriceDisplayWidget(
