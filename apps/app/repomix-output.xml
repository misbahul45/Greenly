Widget _routeHarness(String routeName) {
  return MaterialApp(
    home: Builder(
      builder: (context) {
        final route =
            RouterGenerate.generateRoute(RouteSettings(name: routeName))
                as MaterialPageRoute<dynamic>;
        return route.builder(context);
      },
    ),
  );
}
