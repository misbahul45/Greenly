                  const SizedBox(height: UIConstants.spacingS),
                  Container(
                    color: Colors.white,
                    padding: const EdgeInsets.all(UIConstants.paddingM),
                    child: ProductReviewsWidget(
                      productId: product.id,
                      productName: product.name,
                    ),
                  ),
                  const SizedBox(height: UIConstants.spacingS),
