# Greenly web app local environment.
# TanStack Start runs on Vite; server code reads process.env.
# Do not use these values in production.

NODE_ENV=development
PORT=3000

# API_URL points at the core API for auth/session requests.
API_URL=http://localhost/api/core

# API_BASE_URL/VITE_API_BASE_URL point at the Traefik API root used by dashboard modules.
API_BASE_URL=http://localhost/api
VITE_API_BASE_URL=http://localhost/api

# Required by @tanstack/react-start session cookies. Use at least 32 characters.
SESSION_SECRET=change-me-at-least-32-characters
