# =========================================================
# Greenly Root Environment (EXAMPLE)
# Used by docker-compose.yml
#
# Copy this file to .env and fill in real values.
# Local Docker options are commented as reference/fallback.
# Cloud (Railway/Atlas/Upstash/CloudAMQP) is the active default
# since local dev now connects directly to managed cloud services.
# =========================================================

APP_ENV=development
NODE_ENV=development
APP_NAME=Greenly
COMPOSE_PROJECT_NAME=greenly

# ---------------------------------------------------------
# Network / Gateway
# ---------------------------------------------------------
HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_API_INSECURE=true
DUCKDNS_TOKEN=token_baru_hasil_generate

# ---------------------------------------------------------
# MySQL - core-service
# ---------------------------------------------------------
# --- Local Docker option (uncomment mysql service in docker-compose.yml) ---
# MYSQL_ROOT_PASSWORD=change-me
# MYSQL_DATABASE=greenly_core
# MYSQL_USER=greenly
# MYSQL_PASSWORD=change-me
# MYSQL_PORT=3307
# MYSQL_CONTAINER_PORT=3306
# DATABASE_HOST=mysql
# DATABASE_PORT=3306
# DATABASE_USER=greenly
# DATABASE_PASSWORD=change-me
# DATABASE_NAME=greenly_core
# DATABASE_URL=mysql://greenly:change-me@mysql:3306/greenly_core?allowPublicKeyRetrieval=true

# --- Cloud: Railway MySQL ---
MYSQL_ROOT_PASSWORD=your_railway_mysql_password
MYSQL_DATABASE=railway
MYSQL_USER=root
MYSQL_PASSWORD=your_railway_mysql_password
MYSQL_PORT=your_railway_port
MYSQL_CONTAINER_PORT=3306

DATABASE_HOST=your-project.proxy.rlwy.net
DATABASE_PORT=your_railway_port
DATABASE_USER=root
DATABASE_PASSWORD=your_railway_mysql_password
DATABASE_NAME=railway
DATABASE_URL=mysql://root:your_railway_mysql_password@your-project.proxy.rlwy.net:your_railway_port/railway?allowPublicKeyRetrieval=true
DATABASE_CONNECTION_LIMIT=10

# ---------------------------------------------------------
# MongoDB - catalog-service
# ---------------------------------------------------------
# --- Local Docker option (uncomment mongodb service in docker-compose.yml) ---
# MONGO_INITDB_ROOT_USERNAME=root
# MONGO_INITDB_ROOT_PASSWORD=change-me
# MONGODB_PORT=27017
# MONGODB_CONTAINER_PORT=27017
# MONGODB_DATABASE=catalog
# MONGODB_URL=mongodb://root:change-me@mongodb:27017/?authSource=admin

# --- Cloud: MongoDB Atlas ---
MONGO_INITDB_ROOT_USERNAME=your_atlas_username
MONGO_INITDB_ROOT_PASSWORD=your_atlas_password
MONGODB_HOST=your-cluster.xxxxx.mongodb.net
MONGODB_PORT=27017
MONGODB_CONTAINER_PORT=27017
MONGODB_DATABASE=catalog
# Note: special characters in username/password must be URL-encoded
MONGODB_URL=mongodb+srv://your_atlas_username:your_atlas_password@your-cluster.xxxxx.mongodb.net/catalog?retryWrites=true&w=majority&appName=Greenly

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
# --- Local Docker option (uncomment redis service in docker-compose.yml) ---
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_CONTAINER_PORT=6379
# REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=
# REDIS_POOL_SIZE=10
# REDIS_MAX_RETRIES=3

# --- Cloud: Upstash Redis ---
REDIS_HOST=your-instance.upstash.io
REDIS_PORT=6379
REDIS_CONTAINER_PORT=6379
REDIS_USER=default
REDIS_PASSWORD=your_upstash_redis_password
REDIS_URL=rediss://default:your_upstash_redis_password@your-instance.upstash.io:6379
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3

UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ---------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------
# --- Local Docker option (uncomment rabbitmq service in docker-compose.yml) ---
# RABBITMQ_CONTAINER_NAME=greenly_rabbitmq
# RABBITMQ_HOST=rabbitmq
# RABBITMQ_PORT=5672
# RABBITMQ_CONTAINER_PORT=5672
# RABBITMQ_MANAGEMENT_PORT=15672
# RABBITMQ_MANAGEMENT_CONTAINER_PORT=15672
# RABBITMQ_DEFAULT_USER=greenly
# RABBITMQ_DEFAULT_PASS=change-me
# RABBITMQ_URL=amqp://greenly:change-me@rabbitmq:5672/

# --- Cloud: CloudAMQP (LavinMQ) ---
RABBITMQ_HOST=your-instance.lmq.cloudamqp.com
RABBITMQ_PORT=5671
RABBITMQ_MANAGEMENT_PORT=443
RABBITMQ_DEFAULT_USER=your_cloudamqp_username
RABBITMQ_DEFAULT_PASS=your_cloudamqp_password
RABBITMQ_URL=amqps://your_cloudamqp_username:your_cloudamqp_password@your-instance.lmq.cloudamqp.com/your_cloudamqp_username

RABBITMQ_EXCHANGE=greenly_events
RABBITMQ_CORE_QUEUE=greenly_core_events
RABBITMQ_NO_ACK=false
CORE_RABBITMQ_QUEUE=greenly_queue

OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISH_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=50

# ---------------------------------------------------------
# Core Service - NestJS
# ---------------------------------------------------------
CORE_SERVICE_PORT=3000
CORE_SERVICE_INTERNAL_URL=http://core-service:3000
CORE_SERVICE_PUBLIC_URL=http://localhost/api/core
JWT_ACCESS_SECRET_KEY=change-me-at-least-32-characters
JWT_REFRESH_SECRET_KEY=change-me-at-least-32-characters
JWT_ACCESS_EXPIRES=30d
JWT_REFRESH_EXPIRES=30d
API_URL=http://localhost/api/core

# Base API URL for Flutter Android device/emulator, if applicable.
# Physical device: use your machine's LAN IP, not localhost.
# Emulator: 10.0.2.2 maps to host machine.
MOBILE_API_URL=http://YOUR_MAC_IP/api
ADB_DEVICE=

# Optional email provider used by core-service auth/notification flows.
EMAIL_JS_SERVICE_ID=
EMAIL_JS_PUBLIC_ID=
EMAIL_JS_PRIVATE_KEY=
EMAIL_JS_VERIFY_EMAIL_TEMPLATE_ID=
EMAIL_JS_RESET_PW_TEMPLATE_ID=

# Optional Stripe payment integration.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost/payment-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost/payment-cancel?session_id={CHECKOUT_SESSION_ID}
STRIPE_CURRENCY=idr
STRIPE_CHECKOUT_EXPIRES_HOURS=24

# ---------------------------------------------------------
# Catalog Service - Go Gin
# ---------------------------------------------------------
CATALOG_SERVICE_PORT=8081
CATALOG_SERVICE_INTERNAL_URL=http://catalog-service:8081
CATALOG_SERVICE_PUBLIC_URL=http://localhost/api/catalog
GIN_MODE=debug
IMAGEKIT_PRIVATE_KEY=

# ---------------------------------------------------------
# ML Engine - FastAPI
# ---------------------------------------------------------
ML_ENGINE_PORT=8000
ML_ENGINE_INTERNAL_URL=http://ml-engine:8000
ML_ENGINE_PUBLIC_URL=http://localhost/api/ml
ML_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=/app/app/storage/indexes/products.faiss
PRODUCT_META_PATH=/app/app/storage/indexes/products_meta.json
ML_INTERNAL_TOKEN=change-me-local-dev-token
ML_USE_HASH_EMBEDDINGS=false
HUGGINGFACE_API_TOKEN=change-me


# ---------------------------------------------------------
# Web App - TanStack Start / Vite local development
# ---------------------------------------------------------
WEB_PORT=3000
WEB_PUBLIC_URL=http://localhost:3000
WEB_API_BASE_URL=http://localhost/api
SESSION_SECRET=change-me-at-least-32-characters
VITE_API_BASE_URL=http://localhost/api

# ---------------------------------------------------------
# Scripts
# ---------------------------------------------------------
CATALOG_DIR=services/catalog-service
CORE_DIR=services/core-service

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=debug