# =========================================================
# Greenly Root Environment
# Used by docker-compose.yml
#
# Do not use these values in production.
# Copy this file to .env and replace secrets before running.
# =========================================================

APP_ENV=development
NODE_ENV=development
APP_NAME=Greenly
COMPOSE_PROJECT_NAME=greenly

# ---------------------------------------------------------
# Network / Gateway
# ---------------------------------------------------------
HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080
TRAEFIK_API_INSECURE=true

# ---------------------------------------------------------
# MySQL - core-service
# ---------------------------------------------------------
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=greenly_core
MYSQL_USER=greenly
MYSQL_PASSWORD=change-me
MYSQL_PORT=3307
MYSQL_CONTAINER_PORT=3306
DATABASE_HOST=mysql
DATABASE_CONTAINER_PORT=3306
DATABASE_URL=mysql://greenly:change-me@mysql:3306/greenly_core

# ---------------------------------------------------------
# MongoDB - catalog-service
# ---------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGODB_PORT=27017
MONGODB_CONTAINER_PORT=27017
MONGODB_DATABASE=catalog
MONGODB_URL=mongodb://root:change-me@mongodb:27017/?authSource=admin

# ---------------------------------------------------------
# Redis
# ---------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CONTAINER_PORT=6379
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------
RABBITMQ_CONTAINER_NAME=greenly_rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_CONTAINER_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_MANAGEMENT_CONTAINER_PORT=15672
RABBITMQ_DEFAULT_USER=greenly
RABBITMQ_DEFAULT_PASS=change-me
RABBITMQ_URL=amqp://greenly:change-me@rabbitmq:5672/
RABBITMQ_NO_ACK=false
CORE_RABBITMQ_QUEUE=greenly_queue

# ---------------------------------------------------------
# Core Service - NestJS
# ---------------------------------------------------------
CORE_SERVICE_PORT=3000
CORE_SERVICE_INTERNAL_URL=http://core-service:3000
CORE_SERVICE_PUBLIC_URL=http://localhost/api/core
JWT_ACCESS_SECRET_KEY=change-me-at-least-32-characters
JWT_REFRESH_SECRET_KEY=change-me-at-least-32-characters
JWT_ACCESS_EXPIRES=30d
JWT_REFRESH_EXPIRES=30d
API_URL=http://localhost/api/core

# Optional email provider used by core-service auth/notification flows.
EMAIL_JS_SERVICE_ID=
EMAIL_JS_PUBLIC_ID=
EMAIL_JS_PRIVATE_KEY=
EMAIL_JS_VERIFY_EMAIL_TEMPLATE_ID=

# Optional Stripe payment integration.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost/payment-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost/payment-cancel?session_id={CHECKOUT_SESSION_ID}
STRIPE_CURRENCY=idr
STRIPE_CHECKOUT_EXPIRES_HOURS=24

# ---------------------------------------------------------
# Catalog Service - Go Gin
# ---------------------------------------------------------
CATALOG_SERVICE_PORT=8081
CATALOG_SERVICE_INTERNAL_URL=http://catalog-service:8081
CATALOG_SERVICE_PUBLIC_URL=http://localhost/api/catalog
GIN_MODE=debug
IMAGEKIT_PRIVATE_KEY=

# ---------------------------------------------------------
# ML Engine - FastAPI
# ---------------------------------------------------------
ML_ENGINE_PORT=8000
ML_ENGINE_INTERNAL_URL=http://ml-engine:8000
ML_ENGINE_PUBLIC_URL=http://localhost/api/ml
ML_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
FAISS_INDEX_PATH=/app/app/storage/indexes/products.faiss
PRODUCT_META_PATH=/app/app/storage/indexes/products_meta.json
ML_INTERNAL_TOKEN=change-me-local-dev-token
ML_USE_HASH_EMBEDDINGS=false

# ---------------------------------------------------------
# Web App - TanStack Start / Vite local development
# ---------------------------------------------------------
WEB_PORT=3000
WEB_PUBLIC_URL=http://localhost:3000
WEB_API_BASE_URL=http://localhost/api
SESSION_SECRET=change-me-at-least-32-characters
VITE_API_BASE_URL=http://localhost/api

# ---------------------------------------------------------
# Flutter Mobile App reference
# Android emulator: http://10.0.2.2/api
# iOS simulator: http://localhost/api
# Physical device: http://<your-machine-lan-ip>/api
# ---------------------------------------------------------
MOBILE_API_URL=http://10.0.2.2/api

# ---------------------------------------------------------
# Scripts
# ---------------------------------------------------------
ML_API_URL=http://localhost/api/ml
CATALOG_DIR=services/catalog-service
CORE_DIR=services/core-service

# ---------------------------------------------------------
# Logging
# ---------------------------------------------------------
LOG_LEVEL=debug
