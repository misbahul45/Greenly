                  if (state is AuthAuthenticated) {
                    ScaffoldMessenger.of(context).showSnackBar(
                      const SnackBar(
                        content: Text("Email berhasil diverifikasi"),
                      ),
                    );
                    Navigator.pushReplacementNamed(context, AppRoutes.main);
