    await this.ledgerCreatedPublisher.publish({
      shopId: ledger.shopId,
      type: ledger.type,
      amount: amountVal,
      reference: ledger.reference,
      description: ledger.description || undefined,
      timestamp: ledger.createdAt.toISOString(),
