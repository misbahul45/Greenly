                    context,
                  ).showSnackBar(SnackBar(content: Text(state.message)));
                  if (state.message.contains('Please verify') &&
                      state.email != null) {
                    context.read<AuthBloc>().add(
                      AuthResendOtpRequested(state.email!, OtpType.verifyEmail),
                    );
                    Navigator.pushNamed(
                      context,
                      "/verify-email",
                      arguments: {
                        "email": state.email,
                        "type": OtpType.verifyEmail,
