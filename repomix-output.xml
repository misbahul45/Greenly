                                      color: AppTheme.primaryColor,
                                      size: 18,
                                    ),
                                  ),
                                  const SizedBox(width: UIConstants.spacingM),
                                  const Expanded(
                                    child: Text(
                                      "Masukkan email akun kamu untuk menerima OTP reset password.",
                                      style: TextStyle(
                                        fontSize: UIConstants.fontSizeM,
                                        color: Colors.black54,
                                        height: 1.5,
                                      ),
                                    ),
                                  ),
                                ],
                              ),
                            ),
